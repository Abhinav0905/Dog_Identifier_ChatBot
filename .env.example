# AI provider selection: "openai" (default) or "claude"
MODEL_PROVIDER=openai

# OpenAI API key for vision, chat, and admin analytics
OPENAI_API_KEY=sk-your-openai-key-here

# Optional model overrides
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=
OPENAI_CHAT_MODEL=
OPENAI_ADMIN_MODEL=

# RAG scraping + Pinecone hybrid search
DAR_SCRAPE_BASE_URL=https://dharamsalaanimalrescue.org/
DAR_SCRAPE_MAX_PAGES=80
DAR_CONTACT_URL=https://dharamsalaanimalrescue.org/contact/
RAG_VECTOR_BACKEND=chroma
RAG_SQLITE_EMBEDDINGS=false
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_DENSE_DIMENSION=384
RAG_HYBRID_ALPHA=0.65
RAG_SPARSE_DIMENSION=262144
CHROMA_PERSIST_DIR=
CHROMA_COLLECTION_NAME=dar-rag
CHROMA_HNSW_SPACE=cosine
CHROMA_HNSW_CONSTRUCTION_EF=200
CHROMA_HNSW_SEARCH_EF=100
CHROMA_HNSW_M=16
PINECONE_API_KEY=
PINECONE_INDEX_NAME=dar-rag-hybrid
PINECONE_NAMESPACE=dharamsala-animal-rescue
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Anthropic API key — required when MODEL_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — required when MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here

# Alert webhook URL (optional, logs to console if not set)
ALERT_WEBHOOK_URL=

# Slack webhook URL (optional)
SLACK_WEBHOOK_URL=

# Admin password for analytics endpoints
ADMIN_PASSWORD=

# Public rescue contact shown in guidance responses
DAR_PHONE_NUMBER=

# Twilio WhatsApp Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Keep false for initial sandbox setup; enable after the public webhook URL is stable.
TWILIO_VALIDATE_SIGNATURES=false
# Example: http://3.150.101.119
TWILIO_WEBHOOK_BASE_URL=
# Demo-only: WhatsApp usually strips EXIF GPS from sent photos, so inject a
# Dharamsala test coordinate when no WhatsApp location pin is available.
WHATSAPP_DEMO_LOCATION_FALLBACK=false
WHATSAPP_DEMO_LAT=32.2196
WHATSAPP_DEMO_LNG=76.3234

# Feature flags
STRICT_LOCATION_GATE=true
# Buffer around Deb's named service-area route checkpoints, in km.
DHARAMSALA_SERVICE_POINT_RADIUS_KM=3
# Legacy fallback radius setting; route polygon/checkpoints are the active gate.
DHARAMSALA_REGION_RADIUS_KM=1000

# Server config
HOST=0.0.0.0
PORT=8000
MAX_IMAGE_SIZE_MB=100
VISION_IMAGE_MAX_DIMENSION=2048
VISION_IMAGE_JPEG_QUALITY=88

# Optional persistent paths (useful for Docker/EC2)
DB_PATH=
STORAGE_DIR=
