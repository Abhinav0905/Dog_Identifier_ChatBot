# AI provider selection: "openai" (default) or "claude"
MODEL_PROVIDER=openai

# OpenAI API key for vision, chat, and admin analytics
OPENAI_API_KEY=sk-your-openai-key-here

# Optional model overrides
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=
OPENAI_CHAT_MODEL=
OPENAI_ADMIN_MODEL=

# Anthropic API key — required when MODEL_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — required when MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here

# Alert webhook URL (optional, logs to console if not set)
ALERT_WEBHOOK_URL=

# Slack webhook URL (optional)
SLACK_WEBHOOK_URL=

# Admin password for analytics endpoints
ADMIN_PASSWORD=changeme

# Server config
HOST=0.0.0.0
PORT=8000

# Optional persistent paths (useful for Docker/EC2)
DB_PATH=
STORAGE_DIR=
