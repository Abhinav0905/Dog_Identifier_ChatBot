# AI provider selection: "claude" (default) or "openai"
MODEL_PROVIDER=claude

# Anthropic API key — required when MODEL_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — required when MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here

# Alert webhook URL (optional, logs to console if not set)
ALERT_WEBHOOK_URL=

# Slack webhook URL (optional)
SLACK_WEBHOOK_URL=

# Admin password for analytics endpoints
ADMIN_PASSWORD=changeme

# Server config
HOST=0.0.0.0
PORT=8000
